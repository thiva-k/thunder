# --- LLM Provider ---
# Which LLM to use: "anthropic" (default) or "gemini".
LLM_PROVIDER=anthropic

# Anthropic API key — required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google API key — required when LLM_PROVIDER=gemini.
# GOOGLE_API_KEY=your-google-api-key

# Model name override. Defaults to claude-sonnet-4-6 (Anthropic) or gemini-2.5-flash (Gemini).
# MODEL_NAME=

# --- Thunder (optional) ---
# Leave THUNDER_BASE_URL empty to run without Thunder authentication.
# The API server's demo user (API_REQUIRE_AUTH=false) will be used instead.
THUNDER_BASE_URL=https://localhost:8090

# OAuth client ID and secret of the agent created in Thunder.
# The default secret matches thunderid-config/thunderid.env.
AGENT_ID=WAYFINDER-CONCIERGE
AGENT_SECRET=wayfinder-agent-secret

# Redirect URI used for the on-behalf-of (user-context) authorization-code flow.
AGENT_REDIRECT_URI=http://localhost:5173/agent-callback

# Scope required on the user's token to connect to the chat WebSocket.
# Must match a permission on the wayfinder-agent resource server.
AGENT_ACCESS_SCOPE=agent:access
